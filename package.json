{
  "name": "hytale-generator-webapp",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "frontend",
    "server"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:frontend",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:server": "npm --workspace server run dev",
    "build": "npm-run-all build:frontend build:server",
    "build:frontend": "npm --workspace frontend run build",
    "build:server": "npm --workspace server run build",
    "start": "npm --workspace server run start"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
